# Copy to .dev.vars for `npm run preview`. Do not commit .dev.vars.
AUTH_SECRET=replace-with-a-random-32-plus-character-secret
IP_HASH_SECRET=replace-with-a-different-random-32-plus-character-secret
AUTH_MODE=open

